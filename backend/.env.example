# LLM API Keys (백엔드는 아래 표준 이름을 권장합니다.)
# 같은 파일에 VITE_ANTHROPIC_API_KEY 등만 있어도 인식합니다(프론트와 키를 맞출 때).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Patent DB API Keys
KIPRIS_API_KEY=
EPO_CLIENT_ID=
EPO_CLIENT_SECRET=

# 특허 검색 백엔드: kipris(기본, KIPRIS Plus) | uspto(USPTO ODP, USPTO_API_KEY 필요)
PATENT_SEARCH_BACKEND=kipris

# USPTO Open Data Portal — PATENT_SEARCH_BACKEND=uspto 일 때만 필요
USPTO_API_KEY=

# Uvicorn 은 명령행 `--port` 로 지정합니다. `npm run dev` 에서는 Vite 가 `frontend/.env.development` 의 VITE_API_BASE 로 요청을 프록시하므로, 그 줄만 백엔드 포트와 맞추면 됩니다.
